# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# fvm cache directory (D-14)
.fvm/

# Generated Drift / Riverpod / freezed / flutter_gen codegen output.
# Regenerated on every `dart run build_runner build`. Phase 1 has nothing
# committed under lib/gen/ yet (placeholder .gitkeep only).
**/*.g.dart
**/*.gen.dart
**/*.freezed.dart
!lib/gen/audio_manifest.g.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local screenshot tour artifacts (one-off observation runs).
/screenshots/

# Spectral / acoustic review outputs (regenerable via tools/audio_review/*.py).
# Scripts and REVIEW.md are committed; PNG / JSON outputs and the venv are not.
/audio-review/*
!/audio-review/REVIEW.md
/tools/audio_review/.venv/
